{
  "version": "0.1",
  "workspace": "./topo",
  "outputs": {
    "app": {
      "path": "./app",
      "ownership": "generated"
    }
  },
  "topology": {
    "runtimes": [
      {
        "id": "app_api",
        "kind": "api_service",
        "surface": "proj_api",
        "generator": {
          "id": "topogram/hono",
          "version": "1"
        },
        "port": 3000,
        "uses_database": "app_postgres"
      },
      {
        "id": "app_sveltekit",
        "kind": "web",
        "surface": "proj_web_surface",
        "generator": {
          "id": "topogram/sveltekit",
          "version": "1"
        },
        "port": 5173,
        "uses_api": "app_api"
      },
      {
        "id": "app_postgres",
        "kind": "database",
        "surface": "proj_db_postgres",
        "generator": {
          "id": "topogram/postgres",
          "version": "1"
        },
        "port": 5432
      }
    ]
  }
}
